# =============================================================================
# .gitignore — NYC TLC BI Pipeline
# Covers: Python, dbt, Airflow, Docker, Snowflake, IDE, OS
# =============================================================================


# -----------------------------------------------------------------------------
# SECRETS & CREDENTIALS — never commit these
# -----------------------------------------------------------------------------
.env
*.env
.env.*
!.env.example          # the template is safe to commit

# Snowflake key-pair auth private key (if used instead of password)
*.p8
rsa_key.p8
snowflake_private_key.pem


# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Type checkers & linters cache
.mypy_cache/
.ruff_cache/
.pytype/

# pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb


# -----------------------------------------------------------------------------
# DBT
# -----------------------------------------------------------------------------
# Compiled artefacts (generated at runtime by `dbt run`)
transform/target/
transform/dbt_packages/

# dbt log files
transform/logs/
logs/

# dbt partial parse cache (local only, can cause issues across machines)
transform/target/partial_parse.msgpack

# dbt-fusion user ID file (machine-specific, generated on first run)
transform/.user.yml


# -----------------------------------------------------------------------------
# AIRFLOW
# -----------------------------------------------------------------------------
# Task-instance logs (stored in the named Docker volume, not the repo)
orchestration/logs/

# Airflow local DB (when running standalone outside Docker)
airflow.db
airflow.cfg
airflow_settings.yaml
standalone_admin_password.txt
webserver_config.py


# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
# Docker-generated override files (machine-specific)
docker-compose.override.yml


# -----------------------------------------------------------------------------
# SNOWFLAKE / SQL OUTPUT
# -----------------------------------------------------------------------------
# Any query result CSVs accidentally saved locally
query_results/
*.csv.tmp


# -----------------------------------------------------------------------------
# TERRAFORM
# -----------------------------------------------------------------------------
infra/terraform/.terraform/
infra/terraform/*.tfstate
infra/terraform/*.tfstate.backup
infra/terraform/*.tfplan
infra/terraform/.terraform.lock.hcl


# -----------------------------------------------------------------------------
# IDE & EDITOR
# -----------------------------------------------------------------------------
# VS Code (project-level settings are fine to commit; personal overrides aren't)
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
!.vscode/extensions.json.example

# JetBrains (PyCharm / DataGrip)
.idea/
*.iml

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~


# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------
# Compressed archives
*.zip
*.tar.gz
*.tgz

# Node (if any front-end tooling is added later)
node_modules/

# System specs
.claude/SYSTEM_SPECS.md

# Local features cache parquet
data/*

# Temporary copilot instruction files
.github/copilot-instructions.md
.github/instructions/*